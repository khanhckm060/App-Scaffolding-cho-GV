# Firebase Configuration
# These are automatically handled by the environment, but you can add your own here if needed.

# Gemini AI Configuration
GEMINI_API_KEY=your_api_key_here

# Resend Email Configuration
RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM="English Skills AI <onboarding@resend.dev>"

# Firebase Admin SDK (Serverless context)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_ID=(default)

# Security
CRON_SECRET=random_32_char_secret
APP_BASE_URL=https://your-app.vercel.app

# Test Mode (For QA)
TEST_MODE_ENABLED=false
NEXT_PUBLIC_TEST_MODE_ENABLED=false
NEXT_PUBLIC_TEST_TOKEN=9aa0168224ad1570e95b00ed11301645
