{
  "entities": {
    "Lesson": {
      "title": "Lesson",
      "description": "A listening scaffolding lesson created by a teacher.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the lesson" },
        "script": { "type": "string", "description": "The full listening script" },
        "vocabulary": { "type": "array", "items": { "type": "object" }, "description": "Target vocabulary with definitions and IPA" },
        "steps": { "type": "object", "description": "The 4-step scaffolding content" },
        "teacherId": { "type": "string", "description": "UID of the teacher who created the lesson" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the lesson was created" }
      },
      "required": ["title", "script", "vocabulary", "steps", "teacherId", "createdAt"]
    },
    "Result": {
      "title": "Result",
      "description": "A student's result for a specific lesson.",
      "type": "object",
      "properties": {
        "lessonId": { "type": "string", "description": "ID of the lesson" },
        "studentName": { "type": "string", "description": "Name of the student" },
        "studentEmail": { "type": "string", "description": "Email of the student" },
        "studentId": { "type": "string", "description": "Optional ID of the student" },
        "assignmentId": { "type": "string", "description": "Optional ID of the assignment" },
        "score": { "type": "number", "description": "Total score out of 10" },
        "details": { "type": "object", "description": "Detailed performance in each step" },
        "completedAt": { "type": "string", "format": "date-time", "description": "When the lesson was completed" }
      },
      "required": ["lessonId", "studentName", "score", "details", "completedAt"]
    },
    "Class": {
      "title": "Class",
      "description": "A class created by a teacher.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the class" },
        "teacherId": { "type": "string", "description": "UID of the teacher" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the class was created" }
      },
      "required": ["name", "teacherId", "createdAt"]
    },
    "Student": {
      "title": "Student",
      "description": "A student in a class.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the student" },
        "phone": { "type": "string", "description": "Phone number of the student" },
        "email": { "type": "string", "description": "Email of the student" },
        "classId": { "type": "string", "description": "ID of the class" },
        "teacherId": { "type": "string", "description": "UID of the teacher" }
      },
      "required": ["name", "phone", "email", "classId", "teacherId"]
    },
    "Assignment": {
      "title": "Assignment",
      "description": "A lesson assigned to a class.",
      "type": "object",
      "properties": {
        "lessonId": { "type": "string", "description": "ID of the lesson" },
        "classId": { "type": "string", "description": "ID of the class" },
        "teacherId": { "type": "string", "description": "UID of the teacher" },
        "deadline": { "type": "string", "format": "date-time", "description": "Deadline for the assignment" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the assignment was created" }
      },
      "required": ["lessonId", "classId", "teacherId", "deadline", "createdAt"]
    }
  },
  "firestore": {
    "/lessons/{lessonId}": {
      "schema": "Lesson",
      "description": "Collection of lessons"
    },
    "/results/{resultId}": {
      "schema": "Result",
      "description": "Collection of student results"
    },
    "/classes/{classId}": {
      "schema": "Class",
      "description": "Collection of classes"
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Collection of students"
    },
    "/assignments/{assignmentId}": {
      "schema": "Assignment",
      "description": "Collection of assignments"
    }
  }
}
